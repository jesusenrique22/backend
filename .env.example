# PostgreSQL (local — ajusta usuario/contraseña de pgAdmin)
DATABASE_URL=postgresql://postgres:TU_PASSWORD@localhost:5432/smart_medic

# API REST
PORT=3000
JWT_SECRET=smart-medic-dev-secret

# Gateway WebSocket (servicio separado: realtime-gateway/)
REALTIME_GATEWAY_URL=http://localhost:3001
INTERNAL_REALTIME_SECRET=smart-medic-internal-dev

# Origen del front en Dev Tunnel (opcional; en dev ya se permiten *.devtunnels.ms)
# CORS_ORIGIN=https://xxxx-8088.use2.devtunnels.ms

# Flutter: API_BASE_URL=3000, SOCKET_URL=3001 (ver .env.example en raíz)

# Zona horaria para horarios de citas (hora de pared → UTC)
APP_TIMEZONE=America/Caracas
APP_TZ_OFFSET_MINUTES=-240

# Solo para migrar datos existentes desde MongoDB (opcional)
# MONGODB_URI=mongodb://localhost:27017/smartmedic
