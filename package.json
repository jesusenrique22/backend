{
  "name": "smart-medic-backend",
  "version": "1.0.0",
  "description": "Backend API for Smart Medic (PostgreSQL + Prisma)",
  "packageManager": "pnpm@11.5.1",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "bash ../scripts/run-backend-dev.sh",
    "dev:debug": "bash ../scripts/run-backend-dev-debug.sh",
    "build": "tsc",
    "db:seed": "ts-node-dev --transpile-only src/scripts/seed.ts",
    "db:seed:fresh": "ts-node-dev --transpile-only src/scripts/seed.ts -- --fresh --yes",
    "db:backfill-profiles": "ts-node-dev --transpile-only src/scripts/backfill-profiles.ts",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:migrate-mongo": "ts-node-dev --transpile-only src/scripts/migrate-mongo-to-postgres.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.20",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.8.7",
    "mongoose": "^8.9.5",
    "prisma": "^6.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
